<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Piggsy"
        tools:targetApi="31">
        <activity
            android:name=".ui.activities.AboutActivity"
            android:parentActivityName=".ui.activities.MainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.HistoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.activities.MainActivity" />
        <activity
            android:name=".ui.activities.EditActivity"
            android:exported="false"
            android:parentActivityName=".ui.activities.MainActivity" />
        <activity
            android:name=".ui.activities.CreateActivity"
            android:exported="false"
            android:parentActivityName=".ui.activities.MainActivity" />
        <activity
            android:name=".ui.activities.ArchiveActivity"
            android:exported="false"
            android:parentActivityName=".ui.activities.MainActivity" />
        <activity
            android:name=".ui.activities.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".ui.activities.MainActivity" />
        <activity
            android:name=".ui.activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.nvllz.piggsy.ui.activities.BackupActivity"
            android:exported="false"
            android:theme="@style/Theme.Piggsy"
            android:label="@string/menu_item_backup"
            android:parentActivityName="com.nvllz.piggsy.ui.activities.MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.nvllz.piggsy.ui.activities.MainActivity" />
        </activity>

        <receiver
            android:name=".receiver.DeadlineReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.app.action.SCHEDULE_EXACT_ALARM_PERMISSION_STATE_CHANGED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>